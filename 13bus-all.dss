~ rmatrix = (1.3292 ) 
~ xmatrix = (1.3475 ) 
~ units=mi 

New Linecode.mtx606 nphases=3  Units=mi
~ Rmatrix=[0.791721  |0.318476  0.781649  |0.28345  0.318476  0.791721  ]
~ Xmatrix=[0.438352  |0.0276838  0.396697  |-0.0184204  0.0276838  0.438352  ]
~ Cmatrix=[383.948  |0  383.948  |0  0  383.948  ]

New linecode.mtx607 nphases=1 BaseFreq=60 
~ rmatrix = (1.3425 ) 
~ xmatrix = (0.5124 )
~ cmatrix = [236] 
~ units=mi 

! Line codes for the lateral lines
! 2 parallel 150mm2 3phase cables (AL/XLPE)
New Linecode.mtx3ph nphases=3  Units=km
~ Rmatrix=[0.114  |0.0228  0.114  |0.0228  0.0228  0.114  ]
~ Xmatrix=[0.0359  |0.0072  0.0359  |0.0072  0.0072  0.0359  ]

! 2 parallel 120mm2 1phase cables (AL/XLPE)
New linecode.mtx1ph nphases=1 BaseFreq=60 
~ rmatrix = (0.14 ) 
~ xmatrix = (0.0357 )
~ units=km 

